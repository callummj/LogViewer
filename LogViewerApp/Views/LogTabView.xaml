<UserControl x:Class="LogViewerApp.Views.LogTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:LogViewerApp.Controls"
             xmlns:conv="clr-namespace:LogViewerApp.Converters">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- iOS-style sliding toggle -->
        <Style x:Key="IosToggle" TargetType="ToggleButton">
            <Setter Property="Width"  Value="44"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Cursor="Hand" VerticalAlignment="Center">
                            <!-- Grey off-track (always present underneath) -->
                            <Border Background="#BBBBBB" CornerRadius="12"/>
                            <!-- Blue on-track fades in over the grey -->
                            <Border x:Name="TrackOn"
                                    Background="#0078D4" CornerRadius="12" Opacity="0"/>
                            <!-- Sliding thumb -->
                            <Border x:Name="Thumb"
                                    Width="20" Height="20" CornerRadius="10"
                                    Background="White"
                                    HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Direction="270" ShadowDepth="1"
                                                      BlurRadius="3" Opacity="0.35"/>
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="TrackOn"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="TrackOn"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Margin" Value="0,1,0,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#FAFAFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Loading overlay — sits above everything while IsLoading is true -->
        <Grid Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="10"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Rectangle Fill="White" Opacity="0.75"/>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="220" Height="4"
                             Foreground="#0078D4" Background="#DDDDDD" BorderThickness="0"/>
                <TextBlock Text="{Binding LoadingText}" Margin="0,10,0,0"
                           FontFamily="Consolas" FontSize="12" Foreground="#555"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="5,4"
                BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <WrapPanel>
                <TextBlock Text="Filter:" Foreground="#555" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="12" Margin="0,0,5,0"/>
                <CheckBox Content="ERR" IsChecked="{Binding FilterError}" Foreground="#B01010"
                          FontFamily="Consolas" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                <CheckBox Content="WRN" IsChecked="{Binding FilterWarn}"  Foreground="#9A6A00"
                          FontFamily="Consolas" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                <CheckBox Content="INF" IsChecked="{Binding FilterInfo}"  Foreground="#0060A0"
                          FontFamily="Consolas" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                <CheckBox Content="DBG" IsChecked="{Binding FilterDebug}" Foreground="#555"
                          FontFamily="Consolas" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                <CheckBox Content="TRC" IsChecked="{Binding FilterTrace}" Foreground="#999"
                          FontFamily="Consolas" FontSize="12" Margin="0,0,10,0" VerticalAlignment="Center"/>

                <Separator Width="1" Height="16" Background="#CCC" Margin="0,0,10,0" VerticalAlignment="Center"/>

                <TextBlock Text="Session:" Foreground="#555" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="12" Margin="0,0,4,0"/>
                <ComboBox Width="170" Margin="0,0,4,0" FontFamily="Consolas" FontSize="12"
                          ItemsSource="{Binding Sessions}"
                          DisplayMemberPath="Label"
                          SelectedIndex="{Binding SelectedSessionIndex}"/>
                <Button Content="All" Padding="5,1" Margin="0,0,10,0"
                        Command="{Binding ClearSessionFilterCommand}"
                        FontFamily="Consolas" FontSize="12"/>

                <Separator Width="1" Height="16" Background="#CCC" Margin="0,0,10,0" VerticalAlignment="Center"/>

                <TextBlock Text="Find:" Foreground="#555" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="12" Margin="0,0,4,0"/>
                <TextBox Width="180" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas" FontSize="12"
                         BorderBrush="#BBB" Padding="3,1" Margin="0,0,10,0"/>

                <TextBlock Text="Highlight:" Foreground="#555" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="12" Margin="0,0,4,0"/>
                <TextBox Width="140" Text="{Binding HighlightText, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas" FontSize="12"
                         BorderBrush="#BBB" Padding="3,1" Margin="0,0,10,0"/>

                <Separator Width="1" Height="16" Background="#CCC" Margin="0,0,10,0" VerticalAlignment="Center"/>

                <CheckBox Content="T-Sync" IsChecked="{Binding IsTimeSyncEnabled}"
                          Foreground="#0060A0" FontFamily="Consolas" FontSize="12"
                          VerticalAlignment="Center" Margin="0,0,8,0"
                          ToolTip="Sync cursor position by timestamp across tabs"/>
                <CheckBox Content="S-Sync" IsChecked="{Binding IsSessionSyncEnabled}"
                          Foreground="#007050" FontFamily="Consolas" FontSize="12"
                          VerticalAlignment="Center"
                          ToolTip="Sync active session across tabs"/>

                <Separator Width="1" Height="16" Background="#CCC" Margin="8,0,10,0" VerticalAlignment="Center"/>

                <ToggleButton IsChecked="{Binding IsTextView}"
                              Style="{StaticResource IosToggle}"
                              ToolTip="Switch between structured grid view and raw text view"/>
            </WrapPanel>
        </Border>

        <!-- Raw text view (Notepad-style) -->
        <TextBox Grid.Row="1"
                 Text="{Binding RawText, Mode=OneWay}"
                 IsReadOnly="True"
                 FontFamily="Consolas" FontSize="12"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 Background="White" Foreground="#1A1A1A"
                 BorderThickness="0" Padding="8,6"
                 Visibility="{Binding IsTextView, Converter={StaticResource BoolToVis}}"/>

        <!-- Main split: log list + detail -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsGridView, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <!-- Log entries — text-editor style -->
            <DataGrid Grid.Column="0"
                      x:Name="LogGrid"
                      ItemsSource="{Binding FilteredEntries}"
                      SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEEEEE"
                      HeadersVisibility="Column"
                      Background="White"
                      Foreground="#1A1A1A"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      BorderThickness="0"
                      SelectionMode="Single"
                      RowHeight="19"
                      FontFamily="Consolas"
                      FontSize="12"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F0F0F0"/>
                        <Setter Property="Foreground" Value="#444"/>
                        <Setter Property="FontFamily" Value="Consolas"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="5,3"/>
                        <Setter Property="BorderBrush" Value="#DDDDDD"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{Binding RowBackground}"/>
                        <Setter Property="Foreground" Value="#1A1A1A"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0060A0"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="5,1" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <!-- Line number gutter -->
                    <DataGridTextColumn Binding="{Binding LineNumber}" Width="50" IsReadOnly="True"
                                        SortMemberPath="LineNumber">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Timestamp -->
                    <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="175" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#666666"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Level badge -->
                    <DataGridTemplateColumn Header="Lvl" Width="46" IsReadOnly="True" SortMemberPath="Level">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LevelShort}"
                                           Foreground="{Binding LevelBrush}"
                                           FontWeight="Bold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Thread -->
                    <DataGridTextColumn Header="Thread" Binding="{Binding Thread}" Width="85" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#888888"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Logger (shortened) -->
                    <DataGridTextColumn Header="Logger" Binding="{Binding LoggerShort}" Width="160" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#555577"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Message -->
                    <DataGridTemplateColumn Header="Message" Width="*" IsReadOnly="True" SortMemberPath="Message">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ctrl:HighlightTextBlock SourceText="{Binding Message}"
                                                         Highlight="{Binding DataContext.HighlightText,
                                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Ses" Binding="{Binding SessionIndex}" Width="34" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center"
                          Background="#DDDDDD" ResizeBehavior="PreviousAndNext"/>

            <!-- Detail panel -->
            <Border Grid.Column="2" Background="#F7F7F7"
                    BorderBrush="#DDDDDD" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8">
                    <StackPanel Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVis}}">

                        <TextBlock Text="TIMESTAMP" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding SelectedEntry.Timestamp}" Style="{StaticResource DetailValue}"/>

                        <TextBlock Text="LEVEL" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding SelectedEntry.Level}"
                                   Foreground="{Binding SelectedEntry.LevelBrush}"
                                   FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="0,1,0,8"/>

                        <TextBlock Text="THREAD" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding SelectedEntry.Thread}" Style="{StaticResource DetailValue}"/>

                        <TextBlock Text="LOGGER" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding SelectedEntry.Logger}" Style="{StaticResource DetailValue}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="MESSAGE" Style="{StaticResource DetailLabel}"/>
                        <TextBox Text="{Binding SelectedEntry.Message, Mode=OneWay}"
                                 FontFamily="Consolas" FontSize="12" Foreground="#1A1A1A"
                                 Background="#EFEFEF" BorderThickness="0" IsReadOnly="True"
                                 TextWrapping="Wrap" Margin="0,1,0,8" Padding="4,3"/>

                        <TextBlock Text="EXCEPTION" Style="{StaticResource DetailLabel}"
                                   Visibility="{Binding SelectedEntry.Exception, Converter={StaticResource NullToVis}}"/>
                        <TextBox Text="{Binding SelectedEntry.Exception, Mode=OneWay}"
                                 FontFamily="Consolas" FontSize="11" Foreground="#B01010"
                                 Background="#FDF0F0" BorderBrush="#F0CCCC" BorderThickness="1"
                                 IsReadOnly="True" TextWrapping="Wrap" Margin="0,1,0,8" Padding="4,3"
                                 Visibility="{Binding SelectedEntry.Exception, Converter={StaticResource NullToVis}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="6,2"
                BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="#666"
                       FontFamily="Consolas" FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
