<Window x:Class="LogViewerApp.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About LogViewer"
        Width="380" Height="210"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F0F0F0">

    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="LogViewer"
                   FontSize="22" FontWeight="SemiBold"
                   Foreground="#0078D4"/>

        <TextBlock Grid.Row="1"
                   Text="A WPF log file viewer"
                   FontSize="12" Foreground="#666"
                   Margin="0,3,0,0"/>

        <Separator Grid.Row="2" VerticalAlignment="Center"
                   Background="#CCC" Margin="0,6"/>

        <TextBlock Grid.Row="3"
                   x:Name="VersionText"
                   FontSize="13" Foreground="#1A1A1A"/>

        <TextBlock Grid.Row="4"
                   x:Name="CopyrightText"
                   FontSize="11" Foreground="#888"
                   Margin="0,4,0,0"/>

        <Button Grid.Row="6"
                Content="Close"
                HorizontalAlignment="Right"
                Width="80" Padding="0,6"
                Background="#0078D4" Foreground="White" BorderThickness="0"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
