<Window x:Class="LogViewerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LogViewerApp.ViewModels"
        xmlns:views="clr-namespace:LogViewerApp.Views"
        xmlns:conv="clr-namespace:LogViewerApp.Converters"
        Title="LogViewer" Height="800" Width="1400"
        Background="#F0F0F0"
        WindowState="Maximized">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:InverseNullToVisibilityConverter x:Key="InvNullToVis"/>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <conv:InverseBoolConverter             x:Key="InvBool"/>
        <!-- Proxy gives context-menu items access to MainViewModel -->
        <conv:BindingProxy x:Key="Proxy" Data="{Binding}"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileInNewTabCommand}"/>
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding NewTabCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menu bar -->
        <Menu Grid.Row="0" Background="#E0E0E0" Foreground="#1A1A1A">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#1A1A1A"/>
                </Style>
            </Menu.Resources>
            <MenuItem Header="_File">
                <MenuItem Header="Open Log File(s)…"  Command="{Binding OpenFileInNewTabCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="New Empty Tab"       Command="{Binding NewTabCommand}"           InputGestureText="Ctrl+T"/>
                <Separator/>
                <MenuItem Header="Close Tab"           Command="{Binding CloseTabCommand}"         InputGestureText="Ctrl+W"/>
                <MenuItem Header="Close Unpinned Tabs" Command="{Binding CloseUnpinnedTabsCommand}"/>
                <MenuItem Header="Close All Tabs"      Command="{Binding CloseAllTabsCommand}"/>
            </MenuItem>
            <MenuItem Header="_log4net">
                <MenuItem Header="Load log4net Config…"     Command="{Binding LoadLog4NetConfigCommand}"/>
                <MenuItem Header="Generate Default Config…" Command="{Binding GenerateLog4NetConfigCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#E8E8E8" Padding="6,5"
                BorderBrush="#CCC" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Open Log File(s)" Command="{Binding OpenFileInNewTabCommand}"
                            Margin="0,0,6,0" Padding="10,4"
                            Background="#0078D4" Foreground="White" BorderThickness="0"/>
                    <Button Content="New Tab" Command="{Binding NewTabCommand}"
                            Margin="0,0,4,0" Padding="10,4"
                            Background="#D0D0D0" Foreground="#1A1A1A" BorderBrush="#BBB" BorderThickness="1"/>
                    <Button Content="Close All" Command="{Binding CloseAllTabsCommand}"
                            Margin="0,0,12,0" Padding="10,4"
                            Background="#D0D0D0" Foreground="#1A1A1A" BorderBrush="#BBB" BorderThickness="1"/>

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,12,0"/>

                    <CheckBox Content="Time Sync" IsChecked="{Binding IsTimeSyncGlobal}"
                              Foreground="#0060A0" VerticalAlignment="Center" Margin="0,0,8,0"
                              FontFamily="Consolas" FontSize="12"
                              ToolTip="Synchronize cursor position by timestamp across all tabs"/>
                    <CheckBox Content="Session Sync" IsChecked="{Binding IsSessionSyncGlobal}"
                              Foreground="#007050" VerticalAlignment="Center" Margin="0,0,12,0"
                              FontFamily="Consolas" FontSize="12"
                              ToolTip="Synchronize active session selection across all tabs"/>

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,12,0"/>

                    <TextBlock Text="log4net:" Foreground="#666" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding Log4NetStatus}" Foreground="#0078D4"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="Load Config" Command="{Binding LoadLog4NetConfigCommand}"
                            Padding="8,4" Background="#D0D0D0" Foreground="#1A1A1A"
                            BorderBrush="#BBB" BorderThickness="1" Margin="0,0,4,0"/>
                    <Button Content="Generate Config" Command="{Binding GenerateLog4NetConfigCommand}"
                            Padding="8,4" Background="#D0D0D0" Foreground="#1A1A1A"
                            BorderBrush="#BBB" BorderThickness="1"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Tab control — bound to sorted view so pinned tabs float left -->
        <TabControl Grid.Row="2"
                    ItemsSource="{Binding TabsView}"
                    SelectedItem="{Binding ActiveTab}"
                    Background="#F0F0F0"
                    BorderThickness="0">

            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:LogTabViewModel}">
                    <!-- Border owns the context menu; right-click anywhere on the header -->
                    <Border Background="Transparent" Padding="0">
                        <Border.ContextMenu>
                            <ContextMenu>
                                <!-- Pin / Unpin toggle -->
                                <MenuItem Command="{Binding Data.PinTabCommand, Source={StaticResource Proxy}}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header" Value="Pin Tab"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                    <Setter Property="Header" Value="Unpin Tab"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>

                                <Separator/>

                                <!-- Close Tab — disabled for pinned tabs -->
                                <MenuItem Header="Close Tab"
                                          Command="{Binding Data.CloseTabCommand, Source={StaticResource Proxy}}"
                                          CommandParameter="{Binding}"
                                          IsEnabled="{Binding IsPinned, Converter={StaticResource InvBool}}"/>

                                <MenuItem Header="Close Other Tabs"
                                          Command="{Binding Data.CloseOtherTabsCommand, Source={StaticResource Proxy}}"
                                          CommandParameter="{Binding}"/>

                                <Separator/>

                                <MenuItem Header="Close Unpinned Tabs"
                                          Command="{Binding Data.CloseUnpinnedTabsCommand, Source={StaticResource Proxy}}"/>
                                <MenuItem Header="Close All Tabs"
                                          Command="{Binding Data.CloseAllTabsCommand, Source={StaticResource Proxy}}"/>
                            </ContextMenu>
                        </Border.ContextMenu>

                        <StackPanel Orientation="Horizontal">
                            <!-- Pin indicator -->
                            <TextBlock Text="📌" FontSize="10" Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:LogTabViewModel}">
                    <views:LogTabView DataContext="{Binding}"/>
                </DataTemplate>
            </TabControl.ContentTemplate>

            <TabControl.Style>
                <Style TargetType="TabControl">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Style>
            </TabControl.Style>

            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#DCDCDC"/>
                    <Setter Property="Foreground" Value="#555"/>
                    <Setter Property="BorderThickness" Value="1,1,1,0"/>
                    <Setter Property="BorderBrush" Value="#CCC"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#F0F0F0"/>
                            <Setter Property="Foreground" Value="#1A1A1A"/>
                        </Trigger>
                        <!-- Pinned tabs get a subtle top accent -->
                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                            <Setter Property="BorderBrush" Value="#0078D4"/>
                            <Setter Property="BorderThickness" Value="1,2,1,0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.ItemContainerStyle>
        </TabControl>

        <!-- Empty state -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding ActiveTab, Converter={StaticResource InvNullToVis}}">
            <TextBlock Text="LogViewer" FontSize="28" Foreground="#AAAAAA"
                       HorizontalAlignment="Center" FontWeight="Light"/>
            <TextBlock Text="Open a log file to get started  (Ctrl+O)" FontSize="14" Foreground="#BBBBBB"
                       HorizontalAlignment="Center" Margin="0,8,0,0" FontFamily="Consolas"/>
        </StackPanel>
    </Grid>
</Window>
